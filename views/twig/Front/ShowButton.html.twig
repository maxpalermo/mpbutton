<script type="text/javascript">
    function stickyButtons() {
        const sticky = new StickyPositions();

        const buttonsByPos = {{ {
            top: buttons_top|default([]),
            left: buttons_left|default([]),
            right: buttons_right|default([]),
            center: buttons_center_page|default([]),
            bottom: buttons_bottom|default([]),
            after_cart: buttons_after_cart|default([]),
            description: buttons_description|default([])
        }|json_encode|raw }};
        

        // Funzione helper per creare e aggiungere elementi
        function addButton(position, content, delay, expire) {
            const el = document.createElement("div");
            el.innerHTML = content;
            el.style.backgroundColor = "transparent";
            el.setAttribute("data-delay", delay);
            el.setAttribute("data-expire", expire);
            el.style.display = 'none';
            sticky.addElement(position, el);
        }

        // Aggiungi bottoni per ogni posizione
        Object.keys(buttonsByPos).forEach((pos) => {
            const rawList = buttonsByPos[pos];
            const list = Array.isArray(rawList) ? rawList : (rawList && typeof rawList === 'object' ? Object.values(rawList) : []);
            const position = StickyPositions.POSITIONS[String(pos).toUpperCase()];
            
            if (!position) return;

            list.forEach((but) => {
                const delay = Number(but?.delay || 0) * 1000;
                const expire = Number(but?.expire || 0) * 1000;
                addButton(position, String(but?.content || ""), String(delay), String(expire));
            });
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        console.clear();
        console.log("DOMContentLoaded MpButton");
        
        stickyButtons();
    });
</script>